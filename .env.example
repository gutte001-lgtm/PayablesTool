# PayablesTool environment — copy to ".env" and fill in.
# ".env" is gitignored; never commit real secrets.

# Flask session signing key. Generate a random value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Default password applied to the seed users (marilyn / joe / shaun) by
# init_db.py. Each seeded account is flagged must_change_password=1.
# init_db.py REFUSES to seed if this is empty — it never invents a password.
SEED_DEFAULT_PASSWORD=

# Phase 2 placeholder — base URL OPS-#### links resolve against.
# e.g. https://healthcaremarkets.atlassian.net/browse/
JIRA_BASE_URL=

# Optional. Overrides where the Azure warehouse credentials file is read
# from. Defaults to %LOCALAPPDATA%\AzureWarehouse\azure.env (the same file
# CloseTool uses). Leave unset on Joe's box.
# AZURE_WAREHOUSE_ENV=
